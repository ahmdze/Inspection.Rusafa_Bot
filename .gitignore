```gitignore
# Compiled Python files
*.pyc
__pycache__/

# Dependencies
venv/
.venv/
.env
.env.local
*.env.*

# Logs
*.log

# Coverage reports
.coverage
coverage/
htmlcov/

# IDE files
.vscode/
.idea/
*.swp
*.swo
*.tmp

# Database files (if any SQLite databases are created)
*.db
*.sqlite
*.sqlite3

# Distribution artifacts
dist/
build/
*.egg-info/

# Testing
.pytest_cache/
.mypy_cache/
```